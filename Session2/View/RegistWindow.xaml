<Window x:Class="Desktop.View.RegistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Desktop.View"
        mc:Ignorable="d"
        Title="RegistWindow" Height="550" Width="450">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="1" Grid.Row="0" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30">Создать аккаунт</TextBlock>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="10" x:Name="Surname"/>
        <TextBox Grid.Column="1" Grid.Row="2" Margin="10" x:Name="Firstname"/>
        <TextBox Grid.Column="1" Grid.Row="3" Margin="10" x:Name="Position"/>
        <TextBox Grid.Column="1" Grid.Row="4" Margin="10" x:Name="Phone"/>
        <TextBox Grid.Column="1" Grid.Row="5" Margin="10" x:Name="Cabinet"/>
        <TextBox Grid.Column="1" Grid.Row="6" Margin="10" x:Name="Email"/>
        <PasswordBox Grid.Column="1" Grid.Row="7" Margin="10" x:Name="Password"/>
        <PasswordBox Grid.Column="1" Grid.Row="8" Margin="10" x:Name="RepeatPassword"/>
        <StackPanel Orientation="Horizontal"  Grid.Column="1" Grid.Row="10" Margin="5" HorizontalAlignment="Center">
            <TextBlock>Уже есть аккаунт?    </TextBlock>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top">
   
                <Hyperlink Click="Hyperlink_MouseDown_1" >Войти</Hyperlink>
            </TextBlock>
        </StackPanel>
       
        <Button  Grid.Column="1" Grid.Row="9" Margin="10" Click="Button_Click">
            Зарегистрироваться
        </Button>
    </Grid>
</Window>
